# ==========================================
# Woodivo Monorepo .gitignore
# (backend, cms, frontend, scripts, draft-blogs)
# ==========================================

# ---------- Dependencies ----------
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ---------- Environment files ----------
.env
.env.*
!.env.example
!**/.env.example
backend/.env
frontend/.env
cms/.env
scripts/blog-uploader/.env

# ---------- Build outputs ----------
dist/
build/
out/
**/dist/
**/build/
.next/
.nuxt/
.cache/
.vite/
*.tsbuildinfo

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Testing / coverage ----------
coverage/
*.lcov
.nyc_output/

# ---------- OS files ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------- Editor / IDE ----------
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ---------- NestJS (backend) ----------
backend/dist/
backend/node_modules/

# ---------- React CMS ----------
cms/dist/
cms/node_modules/
cms/build/

# ---------- React frontend (Vite) ----------
frontend/dist/
frontend/dist-ssr/
frontend/node_modules/
frontend/*.local

# ---------- Scripts / blog-uploader ----------
scripts/blog-uploader/node_modules/
scripts/blog-uploader/dist/
scripts/blog-uploader/output/

# ---------- Draft blogs (generated/processed content) ----------
draft-blogs/processed/*.zip
draft-blogs/failed/*
!draft-blogs/failed/.gitkeep
!draft-blogs/processed/.gitkeep

# ---------- Generated at build time (scripts/generate-sitemap.mjs) ----------
frontend/public/sitemap.xml
frontend/public/robots.txt

# ---------- Docker ----------
*.pid
docker-compose.override.yml

# ---------- Stray "* 2" duplicate files (macOS conflicted-copy /
# duplicate-download artifacts, e.g. "backend/.env 2", "Dockerfile 2.md") ----------
* 2
* 2.*

# ---------- Misc ----------
*.tgz
*.tar.gz
.turbo/
.eslintcache
.prettiercache
