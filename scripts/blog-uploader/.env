# Copy this file to .env and fill in real values. Never commit the real .env.

# Base URL of the NestJS backend, including the global prefix.
WOODIVO_API_BASE=http://localhost:4000/api/v1

# An admin/editor account on the backend (needs SUPER_ADMIN, ADMIN, or
# EDITOR role — EDITOR is enough for everything this script does:
# creating blogs, uploading media, and patching the auto-created SEO entry).
WOODIVO_ADMIN_EMAIL=admin@woodivo.com
WOODIVO_ADMIN_PASSWORD=ChangeMe@123

# Folders, relative to this script's location unless given as absolute paths.
DRAFT_BLOGS_DIR=../../draft-blogs
PROCESSED_DIR=../../draft-blogs/processed
FAILED_DIR=../../draft-blogs/failed

# Only used with `npm run watch` (long-running mode). How often to check
# draft-blogs/ for new zips, in minutes.
WATCH_INTERVAL_MINUTES=15
