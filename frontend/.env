# Base URL of the WOODIVO backend API (see backend/README.md).
# Must include the global prefix the API is mounted under (api/v1).
VITE_API_BASE_URL=http://localhost:4000/api/v1

# The frontend's own public URL (its real domain in production). Used only
# by scripts/generate-sitemap.mjs to build absolute <loc> URLs for the
# static sitemap-*.xml / robots.txt files written into public/ — separate
# from VITE_API_BASE_URL, which is where content is fetched FROM, not
# published AT.
VITE_PUBLIC_SITE_URL=http://localhost:5173
