# Base URL of the WOODIVO backend API (see backend/README.md).
# Must include the global prefix the API is mounted under (api/v1).
VITE_API_BASE_URL=http://localhost:4000/api/v1

# The frontend's own public URL (its real domain in production). Read at
# request time by the api/sitemap*.js and api/robots.js serverless
# functions to build absolute <loc> URLs and the Sitemap: line in
# robots.txt — separate from VITE_API_BASE_URL, which is where content is
# fetched FROM, not published AT. Set the real production value in the
# Vercel project's Environment Variables (no VITE_ prefix requirement
# there — that prefix only matters for client-bundle inlining).
VITE_PUBLIC_SITE_URL=http://localhost:5173
